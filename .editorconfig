# Consistent whitespace/encoding across editors and OSes.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{yml,yaml,json,toml,md}]
indent_size = 2

[Makefile]
# make requires tabs in recipes — the tool's oldest sharp edge.
indent_style = tab
