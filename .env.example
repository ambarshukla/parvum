# Copy to .env and adjust if needed. .env is gitignored — real credentials never go in git.
# These defaults are for the LOCAL docker-compose Postgres only; AWS credentials
# will live in GitHub Actions secrets / your AWS profile, never here.
POSTGRES_USER=parvum
POSTGRES_PASSWORD=parvum_local_dev
POSTGRES_DB=parvum
POSTGRES_PORT=5432

# Databricks workspace URL (used by `make land`). Workspace-specific;
# authenticate once with: databricks auth login --host <this URL>
DATABRICKS_HOST=https://dbc-xxxxxxxx-xxxx.cloud.databricks.com

# Contact string for SEC EDGAR requests (used by `make fetch-13f`). SEC's
# fair-access policy requires every request to identify its sender and answers
# HTTP 403 to anything anonymous or without an email — so this has no default:
# a shared one would put someone else's name on your traffic.
SEC_USER_AGENT=Your Name your.email@example.com

# Where the Databricks bronze job sends failure / long-run notifications
# (used by `make deploy-job`). Kept out of the repo — a real address in a
# public bundle is a privacy leak — so it is supplied at deploy time from here.
ALERT_EMAIL=you@example.com

# OpenFIGI API key (used by `make build-master`). OPTIONAL — the client works
# without one at a lower rate limit. A free key (openfigi.com/api) raises the
# allowance. Never commit the real value; it lives here in gitignored .env.
OPENFIGI_API_KEY=your-openfigi-key-here
