# Copy to .env and adjust if needed. .env is gitignored — real credentials never go in git.
# These defaults are for the LOCAL docker-compose Postgres only; AWS credentials
# will live in GitHub Actions secrets / your AWS profile, never here.
POSTGRES_USER=parvum
POSTGRES_PASSWORD=parvum_local_dev
POSTGRES_DB=parvum
POSTGRES_PORT=5432

# Databricks workspace URL (used by `make land`). Workspace-specific;
# authenticate once with: databricks auth login --host <this URL>
DATABRICKS_HOST=https://dbc-xxxxxxxx-xxxx.cloud.databricks.com
