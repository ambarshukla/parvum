{
  "name": "parvum-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Read-only wealth dashboard over the Parvum serving API.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.13.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^25.0.1",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
